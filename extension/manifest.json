{
  "manifest_version": 3,
  "name": "Bipass AI — Auto Typer",
  "version": "1.0.0",
  "description": "Automatically type your Bipass AI results into any text field",
  "action": {
    "default_title": "Bipass AI Auto Typer"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "scripting", "activeTab", "storage", "sidePanel"],
  "host_permissions": [
    "https://bipassai.com/*",
    "https://www.bipassai.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
